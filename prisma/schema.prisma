generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  inventory InventoryItem[]
  history   HistoryItem[]

  devices   Device[]
}

model Category {
  id        Int             @id @default(autoincrement())
  name      String
  avg_days  Int
  items     InventoryItem[]
}

model InventoryItem {
  id               Int      @id @default(autoincrement())
  name             String
  userId           Int
  user             User     @relation(fields: [userId], references: [id])
  categoryId       Int
  category         Category @relation(fields: [categoryId], references: [id])
  expiry_date      DateTime? @db.Date
  quantity         Float
  unit             String
  expiry_estimated Boolean  @default(false)
  notes            String?         @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime        @updatedAt
}

model StatusValidade {
  id        Int             @id @default(autoincrement()) @map("idStatus")
  descricao String?         @map("descricao") @db.VarChar(45)

  @@map("status_validade")
}

model CatalogoProduto {
  barcode                String    @id @map("codigo_barras") @db.VarChar(100)
  nome_produto           String?   @map("nome_produto") @db.VarChar(255)
  marcas                 String?   @map("marcas") @db.VarChar(255)
  categoria              String?   @map("categoria") @db.Text
  quantidade             String?   @map("quantidade") @db.VarChar(100)
  porcao                 String?   @map("porcao") @db.VarChar(100)
  graduacao_nutricional  String?   @map("graduacao_nutricional") @db.Char(1)
  nova_group             Int?      @map("nova_group") @db.TinyInt
  qtd_caloria            Decimal?  @map("qtd_caloria") @db.Decimal(8, 2)
  qtd_gordura            Decimal?  @map("qtd_gordura") @db.Decimal(8, 2)
  qtd_gordura_saturada   Decimal?  @map("qtd_gordura_saturada") @db.Decimal(8, 2)
  qtd_carbo              Decimal?  @map("qtd_carbo") @db.Decimal(8, 2)
  qtd_acucar             Decimal?  @map("qtd_acucar") @db.Decimal(8, 2)
  qtd_proteina           Decimal?  @map("qtd_proteina") @db.Decimal(8, 2)
  qtd_sodio              Decimal?  @map("qtd_sodio") @db.Decimal(8, 2)
  qtd_fibra              Decimal?  @map("qtd_fibra") @db.Decimal(8, 2)
  data_isercao_prod      DateTime? @map("data_isercao_prod")

  @@map("catalogo_produtos")
}

model HistoryItem {
  id             Int      @id @default(autoincrement())
  userId         Int
  user           User     @relation(fields: [userId], references: [id])
  item_name      String
  category_name  String
  quantity       Float
  unit           String
  expiry_date    DateTime @db.Date
  removal_reason String   // 'consumed' | 'expired' | 'donated' | 'other'
  removed_at     DateTime @default(now())
  notes          String?  @db.Text
}

model Mosc {
  id              Int      @id @default(autoincrement()) @map("id_mosc")
  cnpj            String   @db.Char(14)
  cnae            Int? 
  nome_fantasia   String?  @map("nome_fantasia") @db.VarChar(255)
  razao_social    String?  @map("razao_social") @db.VarChar(255)
  latitude        Decimal  @db.Decimal(10, 7)
  longitude       Decimal  @db.Decimal(10, 7)
  municipio       Int?
  municipio_nome  String?  @map("municipio_nome") @db.VarChar(255)
  uf              String?  @db.Char(2)

  @@map("mosc")
}

model Device {
  id        Int      @id @default(autoincrement())
  token     String   @unique @db.VarChar(255)
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@map("devices")
}